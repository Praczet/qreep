#!/usr/bin/env python3
# Description: Fetch Microsoft Outlook calendar events read-only and write Qreep's Microsoft calendar cache.
# Usage: qreep-calendar-microsoft-sync_v0.0.1 [--config PATH] [--state PATH] [--output PATH]
# Install: install -Dm755 scripts/qreep-calendar-microsoft-sync_v0.0.1 "$HOME/.local/bin/qreep-calendar-microsoft-sync"

import argparse
import base64
import hashlib
import json
import os
import secrets
import shutil
import subprocess
import sys
import tempfile
import time
import urllib.parse
import urllib.request
import webbrowser
from datetime import datetime, timedelta, timezone
from http.server import BaseHTTPRequestHandler, HTTPServer
from pathlib import Path


GRAPH_ROOT = "https://graph.microsoft.com/v1.0"
DEFAULT_TENANT = "common"
DEFAULT_SCOPE = "offline_access https://graph.microsoft.com/Calendars.Read"
DEFAULT_CONFIG = Path.home() / ".config" / "qreep" / "calendar" / "microsoft.json"
DEFAULT_STATE = Path.home() / ".local" / "state" / "qreep" / "calendar" / "microsoft-token.json"
DEFAULT_OUTPUT = Path.home() / ".cache" / "qreep" / "calendar" / "microsoft-events.json"


class OAuthCallbackHandler(BaseHTTPRequestHandler):
    server_version = "QreepMicrosoftOAuth/0.1"

    def do_GET(self):
        query = urllib.parse.parse_qs(urllib.parse.urlparse(self.path).query)
        self.server.oauth_code = query.get("code", [""])[0]
        self.server.oauth_error = query.get("error", [""])[0]
        self.server.oauth_state = query.get("state", [""])[0]
        body = b"Qreep Microsoft Calendar auth received. You can close this tab.\n"
        self.send_response(200 if self.server.oauth_code else 400)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, format, *args):
        return


def parse_args():
    parser = argparse.ArgumentParser(
        description="Fetch Microsoft Outlook calendar events read-only and write Qreep's Microsoft calendar cache."
    )
    parser.add_argument("--config", default=str(DEFAULT_CONFIG), help=f"Config path. Default: {DEFAULT_CONFIG}")
    parser.add_argument("--state", default=str(DEFAULT_STATE), help=f"OAuth token path. Default: {DEFAULT_STATE}")
    parser.add_argument("--output", default=str(DEFAULT_OUTPUT), help=f"Output cache path. Default: {DEFAULT_OUTPUT}")
    parser.add_argument("--days-back", type=int, default=7, help="Days before today to fetch. Default: 7")
    parser.add_argument("--days-forward", type=int, default=45, help="Days after today to fetch. Default: 45")
    parser.add_argument("--calendar", action="append", dest="calendars", help="Calendar id to fetch. Can be repeated.")
    parser.add_argument("--no-browser", action="store_true", help="Print auth URL instead of opening a browser.")
    parser.add_argument("--no-qreep-refresh", action="store_true", help="Do not ask running Qreep to reload calendar caches after writing.")
    parser.add_argument("--dry-run", action="store_true", help="Print generated cache JSON instead of writing it.")
    return parser.parse_args()


def read_json(path, default=None):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return json.load(handle)
    except FileNotFoundError:
        return default


def write_json_atomic(path, document, mode=0o600):
    output_path = Path(path).expanduser()
    output_path.parent.mkdir(parents=True, exist_ok=True)

    with tempfile.NamedTemporaryFile(
        "w",
        encoding="utf-8",
        dir=output_path.parent,
        prefix=f".{output_path.name}.",
        delete=False,
    ) as handle:
        json.dump(document, handle, indent=2, sort_keys=True)
        handle.write("\n")
        temporary_path = handle.name

    os.chmod(temporary_path, mode)
    os.replace(temporary_path, output_path)


def refresh_qreep_calendar():
    quickshell = shutil.which("quickshell")
    if not quickshell:
        return

    target = os.environ.get("QREEP_QUICKSHELL_TARGET", "-c qreep").split()
    command = [
        quickshell,
        "ipc",
        *target,
        "--any-display",
        "call",
        "qreep-calendar",
        "refresh",
    ]

    subprocess.run(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False)


def load_config(path):
    config = read_json(Path(path).expanduser(), {})
    if not isinstance(config, dict):
        raise SystemExit("Microsoft calendar config must be a JSON object.")

    if not config.get("client_id"):
        raise SystemExit(f"Missing client_id in {path}")

    config.setdefault("tenant", DEFAULT_TENANT)
    config.setdefault("scope", DEFAULT_SCOPE)
    return config


def auth_url(config):
    tenant = urllib.parse.quote(config.get("tenant") or DEFAULT_TENANT, safe="")
    return f"https://login.microsoftonline.com/{tenant}/oauth2/v2.0/authorize"


def token_url(config):
    tenant = urllib.parse.quote(config.get("tenant") or DEFAULT_TENANT, safe="")
    return f"https://login.microsoftonline.com/{tenant}/oauth2/v2.0/token"


def token_expired(token):
    return not token or time.time() >= float(token.get("expires_at", 0)) - 60


def request_json(url, data=None, headers=None):
    encoded_data = None
    request_headers = headers or {}

    if data is not None:
        encoded_data = urllib.parse.urlencode(data).encode("utf-8")
        request_headers = {"Content-Type": "application/x-www-form-urlencoded", **request_headers}

    request = urllib.request.Request(url, data=encoded_data, headers=request_headers)

    try:
        with urllib.request.urlopen(request, timeout=30) as response:
            return json.loads(response.read().decode("utf-8"))
    except urllib.error.HTTPError as error:
        body = error.read().decode("utf-8", errors="replace")
        raise SystemExit(f"HTTP {error.code} from {url}: {body}") from error


def code_verifier_pair():
    verifier = base64.urlsafe_b64encode(secrets.token_bytes(48)).decode("ascii").rstrip("=")
    digest = hashlib.sha256(verifier.encode("ascii")).digest()
    challenge = base64.urlsafe_b64encode(digest).decode("ascii").rstrip("=")
    return verifier, challenge


def authorize(config, state_path, no_browser):
    verifier, challenge = code_verifier_pair()
    auth_state = secrets.token_urlsafe(24)

    server = HTTPServer(("127.0.0.1", 0), OAuthCallbackHandler)
    server.oauth_code = ""
    server.oauth_error = ""
    server.oauth_state = ""
    redirect_uri = f"http://localhost:{server.server_port}/"

    params = {
        "client_id": config["client_id"],
        "redirect_uri": redirect_uri,
        "response_type": "code",
        "response_mode": "query",
        "scope": config["scope"],
        "code_challenge": challenge,
        "code_challenge_method": "S256",
        "state": auth_state,
    }
    url = auth_url(config) + "?" + urllib.parse.urlencode(params)

    if no_browser:
        print(url)
    else:
        webbrowser.open(url)
        print("Opened Microsoft auth URL in the default browser.")

    print("Waiting for OAuth callback on", redirect_uri)
    server.handle_request()

    if server.oauth_error:
        raise SystemExit(f"Microsoft auth failed: {server.oauth_error}")
    if server.oauth_state != auth_state:
        raise SystemExit("Microsoft auth failed: state mismatch.")
    if not server.oauth_code:
        raise SystemExit("Microsoft auth failed: no code returned.")

    token_request = {
        "client_id": config["client_id"],
        "scope": config["scope"],
        "code": server.oauth_code,
        "code_verifier": verifier,
        "grant_type": "authorization_code",
        "redirect_uri": redirect_uri,
    }
    if config.get("client_secret"):
        token_request["client_secret"] = config["client_secret"]

    token = request_json(token_url(config), token_request)
    token["expires_at"] = time.time() + float(token.get("expires_in", 3600))
    write_json_atomic(state_path, token)
    return token


def refresh_token(config, state_path, token):
    refresh_token_value = token.get("refresh_token")
    if not refresh_token_value:
        return None

    token_request = {
        "client_id": config["client_id"],
        "scope": config["scope"],
        "refresh_token": refresh_token_value,
        "grant_type": "refresh_token",
    }
    if config.get("client_secret"):
        token_request["client_secret"] = config["client_secret"]

    refreshed = request_json(token_url(config), token_request)
    refreshed["refresh_token"] = refreshed.get("refresh_token", refresh_token_value)
    refreshed["expires_at"] = time.time() + float(refreshed.get("expires_in", 3600))
    write_json_atomic(state_path, refreshed)
    return refreshed


def access_token(config, state_path, no_browser):
    token = read_json(Path(state_path).expanduser(), None)

    if not token_expired(token):
        return token

    if token:
        refreshed = refresh_token(config, state_path, token)
        if refreshed:
            return refreshed

    return authorize(config, state_path, no_browser)


def rfc3339_range(days_back, days_forward):
    now = datetime.now(timezone.utc)
    start = datetime(now.year, now.month, now.day, tzinfo=timezone.utc) - timedelta(days=days_back)
    end = start + timedelta(days=days_back + days_forward + 1)
    return start.isoformat().replace("+00:00", "Z"), end.isoformat().replace("+00:00", "Z")


def fetch_calendar_events(token, calendar_id, calendar_label, days_back, days_forward):
    start, end = rfc3339_range(days_back, days_forward)
    events = []
    url = calendar_view_url(calendar_id, start, end)

    while url:
        document = request_json(
            url,
            headers={
                "Authorization": "Bearer " + token["access_token"],
                "Prefer": 'outlook.timezone="UTC"',
            },
        )

        for item in document.get("value", []):
            events.append(microsoft_event(calendar_id, calendar_label, item))

        url = document.get("@odata.nextLink", "")

    return events


def calendar_view_url(calendar_id, start, end):
    params = {
        "startDateTime": start,
        "endDateTime": end,
        "$top": "1000",
    }

    if calendar_id == "default":
        path = "/me/calendar/calendarView"
    else:
        path = "/me/calendars/" + urllib.parse.quote(calendar_id, safe="") + "/calendarView"

    return GRAPH_ROOT + path + "?" + urllib.parse.urlencode(params)


def microsoft_event(calendar_id, calendar_label, item):
    start = item.get("start", {})
    end = item.get("end", {})
    reminder_minutes = []

    if item.get("isReminderOn") and isinstance(item.get("reminderMinutesBeforeStart"), int):
        reminder_minutes.append(item["reminderMinutesBeforeStart"])

    return {
        "id": "microsoft:" + calendar_id + ":" + item.get("id", ""),
        "source": "microsoft",
        "calendar": calendar_label,
        "title": item.get("subject", "Untitled event"),
        "date": start.get("dateTime", ""),
        "start": start.get("dateTime", ""),
        "end": end.get("dateTime", ""),
        "allDay": bool(item.get("isAllDay")),
        "location": location_label(item.get("location")),
        "url": item.get("webLink", ""),
        "color": "",
        "reminderMinutes": reminder_minutes,
        "busy": item.get("showAs") not in ["free", "unknown"],
        "status": "cancelled" if item.get("isCancelled") else "",
    }


def location_label(location):
    if not isinstance(location, dict):
        return ""

    return str(location.get("displayName") or "").strip()


def normalize_document(events):
    return {"events": sorted(events, key=lambda event: (str(event.get("date", "")), str(event.get("start", ""))))}


def configured_calendars(config, cli_calendars):
    if cli_calendars:
        return [{"id": calendar_id, "name": calendar_id} for calendar_id in cli_calendars]

    calendars = config.get("calendars") or [{"id": "default", "name": "Microsoft"}]
    result = []

    for calendar in calendars:
        if isinstance(calendar, str):
            result.append({"id": calendar, "name": calendar})
        elif isinstance(calendar, dict) and calendar.get("id"):
            result.append({"id": calendar["id"], "name": calendar.get("name") or calendar["id"]})

    return result


def main():
    args = parse_args()
    config = load_config(args.config)
    token = access_token(config, args.state, args.no_browser)
    events = []

    for calendar in configured_calendars(config, args.calendars):
        events.extend(
            fetch_calendar_events(
                token,
                calendar["id"],
                calendar["name"],
                args.days_back,
                args.days_forward,
            )
        )

    document = normalize_document(events)

    if args.dry_run:
        json.dump(document, sys.stdout, indent=2, sort_keys=True)
        sys.stdout.write("\n")
        return 0

    write_json_atomic(args.output, document, mode=0o600)
    if not args.no_qreep_refresh:
        refresh_qreep_calendar()

    print(f"Wrote {len(document['events'])} Microsoft events to {Path(args.output).expanduser()}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
