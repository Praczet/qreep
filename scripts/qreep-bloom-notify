#!/usr/bin/env bash
# %name: qreep-bloom-notify
# %desc: Translate Unclaimed Bloom notify commands into Qreep Bloom IPC calls.
# %usage: qreep-bloom-notify bloom-show <profile> [--wallpaper <path>]

set -euo pipefail

QREEP_CONFIG="${QREEP_CONFIG:-qreep}"
QREEP_PATH="${QREEP_PATH:-}"

ipc() {
    export QREEP_CONFIG QREEP_PATH

    if [[ -n "$QREEP_PATH" ]]; then
        /usr/bin/zsh -lc 'quickshell ipc --path "$QREEP_PATH" --newest --any-display call qreep-bloom "$@"' qreep-bloom "$@"
    else
        /usr/bin/zsh -lc 'quickshell ipc -c "$QREEP_CONFIG" --newest --any-display call qreep-bloom "$@"' qreep-bloom "$@"
    fi
}

cmd="${1:-}"
shift || true

case "$cmd" in
    bloom-show)
        profile="${1:-}"
        if [[ -z "$profile" ]]; then
            printf 'usage: qreep-bloom-notify bloom-show <profile> [--wallpaper <path>]\n' >&2
            exit 2
        fi

        wallpaper=""
        shift || true
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --wallpaper)
                    wallpaper="${2:-}"
                    shift 2 || true
                    ;;
                *)
                    shift
                    ;;
            esac
        done

        ipc showBloom "$profile" "$wallpaper"
        ;;
    bloom-done)
        ipc doneBloom
        ;;
    bloom-hide)
        ipc hideBloom
        ;;
    bloom-pickup)
        ipc pickupBloom
        ;;
    *)
        printf 'qreep-bloom-notify: unknown command: %s\n' "$cmd" >&2
        exit 2
        ;;
esac
