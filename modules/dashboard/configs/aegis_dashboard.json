{
  "cardStyle": {
    "color": "{{on_surface}}",
    "backgroundColor": "{{surface}}",
    "borderColor": "{{outline}}",
    "radius": 18,
    "borderWidth": 1,
    "padding": 20
  },
  "blocks": [
    {
      "id": "clock-analog",
      "type": "clock",
      "title": "Clock",
      "text": "",
      "preset": "large",
      "anchorPoint": "top-center",
      "dx": -940,
      "dy": 145,
      "width": 280,
      "height": 300,
      "from": "top-left",
      "showTitle": false,
      "showBackground": false,
      "showBorder": false,
      "config": {
        "faceColor": "{{surface}}",
        "faceOpacity": 1,
        "showBorder": false,
        "showBackground": false,
        "showHourHand": true,
        "showMinuteHand": true,
        "showSecondHand": true,
        "showHourMarkers": true,
        "showMinuteMarkers": false,
        "showDigitalClock": true,
        "showDate": true,
        "showDayOfWeek": false,
        "showSeconds": true
      }
    },
    {
      "id": "borg-backup",
      "type": "borg",
      "title": "Borg",
      "preset": "status",
      "anchorPoint": "top-center",
      "dx": -940,
      "dy": 465,
      "width": 360,
      "height": 220,
      "from": "left",
      "showTitle": false,
      "showBackground": true,
      "showBorder": true,
      "config": {
        "cacheDir": "~/.cache/qreep/borg"
      }
    },
    {
      "id": "aegis-full",
      "type": "aegis",
      "title": "",
      "preset": "system",
      "anchorPoint": "top-center",
      "dx": -50,
      "dy": 165,
      "width": 1200,
      "height": 720,
      "from": "top",
      "showTitle": false,
      "showBackground": true,
      "showBorder": true,
      "config": {
        "mode": "full",
        "layout": "wide"
      }
    },
    {
      "id": "cpu-graph",
      "type": "aegis-cpu-graph",
      "title": "CPU",
      "preset": "chart",
      "anchorPoint": "top-center",
      "dx": 851,
      "dy": 165,
      "width": 525,
      "height": 220,
      "from": "top-right",
      "showTitle": true,
      "showBackground": true,
      "showBorder": true,
      "config": {
        "size": 300
      }
    },
    {
      "id": "mem-pie",
      "type": "aegis-memory-pie",
      "title": "Memory",
      "preset": "chart",
      "anchorPoint": "top-center",
      "dx": 851,
      "dy": 415,
      "width": 525,
      "height": 220,
      "from": "right",
      "showTitle": true,
      "showBackground": true,
      "showBorder": true,
      "config": {
        "size": 300,
        "legendPosition": "left"
      }
    },
    {
      "id": "disk-pie",
      "type": "aegis-disk-pie",
      "title": "Disk",
      "preset": "chart",
      "anchorPoint": "top-center",
      "dx": 851,
      "dy": 669,
      "width": 525,
      "height": 220,
      "from": "right",
      "showTitle": true,
      "showBackground": true,
      "showBorder": true,
      "config": {
        "size": 300,
        "legendPosition": "left"
      }
    },
    {
      "id": "aegis-copy-footer",
      "type": "aegis-copy-footer",
      "title": "Copy",
      "preset": "footer",
      "anchorPoint": "top-center",
      "dx": 0,
      "dy": 900,
      "width": 280,
      "height": 24,
      "from": "bottom",
      "showTitle": false,
      "showBackground": false,
      "showBorder": false,
      "padding": 0,
      "config": {}
    }
