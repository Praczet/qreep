{
  "cardStyle": {
    "color": "{{on_surface}}",
    "backgroundColor": "{{surface}}",
    "borderColor": "{{outline}}",
    "radius": 18,
    "borderWidth": 1,
    "padding": 20
  },
  "blocks": [
    {
      "id": "clock-analog",
      "type": "clock",
      "title": "Clock",
      "text": "",
      "preset": "large",
      "anchorPoint": "top-center",
      "dx": -480,
      "dy": 110,
      "width": 280,
      "height": 300,
      "from": "top-left",
      "showTitle": false,
      "showBackground": false,
      "showBorder": false,
      "config": {
        "faceColor": "{{surface}}",
        "faceOpacity": 1,
        "showBorder": false,
        "showBackground": false,
        "showHourHand": true,
        "showMinuteHand": true,
        "showSecondHand": true,
        "showHourMarkers": true,
        "showMinuteMarkers": false,
        "showDigitalClock": true,
        "showDate": true,
        "showDayOfWeek": false,
        "showSeconds": true
      }
    },
    {
      "id": "weather",
      "type": "weather",
      "title": "Weather",
      "text": "Weather preview block. Real weather can wait until the canvas behaves.",
      "preset": "compact",
      "anchorPoint": "top-center",
      "dx": -480,
      "dy": 430,
      "width": 500,
      "height": 320,
      "from": "left",
      "showTitle": false,
      "showBackground": true,
      "showBorder": true,
      "config": {
        "apiEnabled": true,
        "location": "Bergem, Luxembourg",
        "latitude": 49.5,
        "longitude": 6.1,
        "timezone": "Europe/Luxembourg",
        "refreshInterval": 1800000,
        "temperature": "37°C",
        "condition": "Overcast",
        "wind": "Wind 9 km/h",
        "icon": "weather-overcast-symbolic",
        "forecast": []
      }
    },
    {
      "id": "wotd-compact",
      "type": "word-of-the-day",
      "title": "Word of the Day",
      "preset": "wide",
      "anchorPoint": "top-center",
      "dx": -480,
      "dy": 770,
      "width": 500,
      "height": 310,
      "from": "bottom-left",
      "showTitle": false,
      "showBackground": true,
      "showBorder": true,
      "borderColor": "{{outline}}",
      "radius": 18,
      "padding": 20,
      "config": {
        "variant": "compact",
        "maxMeanings": 3,
        "maxTranslations": 0,
        "maxWidth": 450,
        "minHeight": 300,
        "showTitle": false,
        "showLang": false,
        "showDate": false,
        "showWord": true,
        "showPronunciation": true,
        "showPartOfSpeech": true,
        "showDefinition": true,
        "showMeanings": true,
        "showTranslations": false,
        "wordPixelSize": 36,
        "spacing": 8
      }
    },
    {
      "id": "potato-weight",
      "type": "image",
      "title": "POTATO weight",
      "preset": "chart",
      "anchorPoint": "top-center",
      "dx": 200,
      "dy": 110,
      "width": 800,
      "height": 300,
      "from": "top-right",
      "showTitle": false,
      "showBackground": true,
      "showBorder": false,
      "config": {
        "path": "~/.cache/potato/weight.svg",
        "fillMode": "preserveAspectFit",
        "showBackground": false,
        "radius": 18
      }
    },
    {
      "id": "potato-steps",
      "type": "image",
      "title": "POTATO steps",
      "preset": "chart",
      "anchorPoint": "top-center",
      "dx": 200,
      "dy": 430,
      "width": 800,
      "height": 320,
      "from": "right",
      "showTitle": false,
      "showBackground": true,
      "showBorder": false,
      "config": {
        "path": "~/.cache/potato/steps.svg",
        "fillMode": "preserveAspectFit",
        "radius": 18
      }
    },
    {
      "id": "potato-fasting",
      "type": "image",
      "title": "POTATO fasting",
      "preset": "chart",
      "anchorPoint": "top-center",
      "dx": 200,
      "dy": 770,
      "width": 800,
      "height": 310,
      "from": "bottom-right",
      "showTitle": false,
      "showBackground": true,
      "showBorder": false,
      "config": {
        "path": "~/.cache/potato/fasting.svg",
        "fillMode": "preserveAspectFit",
        "radius": 18
      }
    }
  ]
}
